import nltk
import spacy
import string

from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer
from sklearn.metrics import precision_score, recall_score, f1_score, accuracy_score

# Download NLTK data
nltk.download('punkt')
nltk.download('stopwords')

# Load spaCy model
nlp = spacy.load("en_core_web_sm")

# Input sentences
sentences = [
    "I love learning natural language processing.",
    "Python is a powerful programming language.",
    "Text preprocessing is an important step in NLP."
]

# Gold data
gold_data = [
    ["love", "learning", "natural", "language", "processing"],
    ["python", "powerful", "programming", "language"],
    ["text", "preprocessing", "important", "step", "nlp"]
]

# Tools
stop_words = set(stopwords.words("english"))
stemmer = PorterStemmer()

nltk_results = []
spacy_results = []

print("===== NLTK =====")
for sent in sentences:
    tokens = word_tokenize(sent)
    tokens = [w.lower() for w in tokens]
    tokens = [w for w in tokens if w not in stop_words and w not in string.punctuation]
    stemmed = [stemmer.stem(w) for w in tokens]
    print(tokens, "->", stemmed)
    nltk_results.append(tokens)

print("\n===== spaCy =====")
for sent in sentences:
    doc = nlp(sent)
    tokens = [t.text.lower() for t in doc if not t.is_stop and not t.is_punct]
    lemmas = [t.lemma_.lower() for t in doc if not t.is_stop and not t.is_punct]
    print(tokens, "->", lemmas)
    spacy_results.append(tokens)

def evaluate(predicted, gold):
    y_true, y_pred = [], []
    for p, g in zip(predicted, gold):
        words = list(set(p + g))
        for w in words:
            y_true.append(1 if w in g else 0)
            y_pred.append(1 if w in p else 0)

    return (
        accuracy_score(y_true, y_pred),
        precision_score(y_true, y_pred),
        recall_score(y_true, y_pred),
        f1_score(y_true, y_pred),
    )

print("\n===== RESULTS =====")
print("NLTK:", evaluate(nltk_results, gold_data))
print("spaCy:", evaluate(spacy_results, gold_data))
